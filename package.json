{
  "name": "rts-op",
  "version": "1.0.0",
  "main": "dist/main/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build:ts && npm run build:renderer && node scripts/run-electron.js",
    "build": "npm run build:ts && npm run build:renderer",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --linux AppImage deb",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "dist:all": "npm run build && electron-builder --win nsis portable --linux AppImage deb",
    "build:ts": "rimraf dist && tsc",
    "build:renderer": "npm --prefix src/renderer run build",
    "dev:renderer": "npm --prefix src/renderer run dev",
    "dev:electron": "npm run build:ts && node scripts/run-electron.js --renderer-url=http://localhost:5173",
    "dev": "tsc -w",
    "electron-dev": "node scripts/run-electron.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Desktop приложение для регистрации оперативных автомобилей",
  "devDependencies": {
    "@types/react-dom": "^19.1.2",
    "@types/sqlite3": "^5.1.0",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "rimraf": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@mui/icons-material": "^7.0.1",
    "@mui/lab": "^7.0.0-beta.10",
    "@mui/material": "^7.0.1",
    "@mui/x-date-pickers": "^7.28.2",
    "electron-print-preview": "^2.2.0",
    "react-router-dom": "^7.4.1",
    "react-to-print": "^3.0.6",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "build": {
    "appId": "kg.gov.rtsop",
    "productName": "RTS-OP",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/sqlite3/**/*"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
